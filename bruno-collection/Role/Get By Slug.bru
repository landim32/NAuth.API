meta {
  name: Get By Slug
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/role/getBySlug/:slug
  body: none
  auth: bearer
}

headers {
  X-Tenant-Id: fortuno
  ~X-Tenant-Id: emagine
  ~X-Tenant-Id: viralt
  ~X-Tenant-Id: devblog
  ~X-Tenant-Id: bazzuca
  ~X-Tenant-Id: monexup
}

params:path {
  slug: admin
}

auth:bearer {
  token: {{token}}
}
