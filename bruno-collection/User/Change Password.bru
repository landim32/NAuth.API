meta {
  name: Change Password
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/user/changePassword
  body: json
  auth: bearer
}

headers {
  X-Tenant-Id: fortuno
  ~X-Tenant-Id: emagine
  ~X-Tenant-Id: viralt
  ~X-Tenant-Id: devblog
  ~X-Tenant-Id: bazzuca
  ~X-Tenant-Id: monexup
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "oldPassword": "P@ssw0rd123",
    "newPassword": "NewP@ssw0rd456"
  }
}
