meta {
  name: Get By Id
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/user/getById/:userId
  body: none
  auth: bearer
}

headers {
  X-Tenant-Id: fortuno
  ~X-Tenant-Id: emagine
  ~X-Tenant-Id: viralt
  ~X-Tenant-Id: devblog
  ~X-Tenant-Id: bazzuca
  ~X-Tenant-Id: monexup
}

params:path {
  userId: 1
}

auth:bearer {
  token: {{token}}
}
