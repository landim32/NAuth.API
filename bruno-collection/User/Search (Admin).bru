meta {
  name: Search (Admin)
  type: http
  seq: 14
}

post {
  url: {{baseUrl}}/user/search
  body: json
  auth: bearer
}

headers {
  X-Tenant-Id: fortuno
  ~X-Tenant-Id: emagine
  ~X-Tenant-Id: viralt
  ~X-Tenant-Id: devblog
  ~X-Tenant-Id: bazzuca
  ~X-Tenant-Id: monexup
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "searchTerm": "john",
    "page": 1,
    "pageSize": 10
  }
}
