meta {
  name: Get By Email
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/user/getByEmail/:email
  body: none
  auth: bearer
}

headers {
  X-Tenant-Id: fortuno
  ~X-Tenant-Id: emagine
  ~X-Tenant-Id: viralt
  ~X-Tenant-Id: devblog
  ~X-Tenant-Id: bazzuca
  ~X-Tenant-Id: monexup
}

params:path {
  email: john@example.com
}

auth:bearer {
  token: {{token}}
}
