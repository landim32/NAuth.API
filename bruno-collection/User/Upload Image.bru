meta {
  name: Upload Image
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/user/uploadImageUser
  body: multipartForm
  auth: bearer
}

headers {
  X-Tenant-Id: fortuno
  ~X-Tenant-Id: emagine
  ~X-Tenant-Id: viralt
  ~X-Tenant-Id: devblog
  ~X-Tenant-Id: bazzuca
  ~X-Tenant-Id: monexup
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  file: @file()
}
